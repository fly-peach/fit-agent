{
  "app_name": "FitAgent",
  "app_version": "1.0.0",
  "debug": true,
  "server_host": "127.0.0.1",
  "server_port": 8000,
  "database_url": "sqlite:///./db/fitagent.db",
  "jwt_secret_key": "your-secret-key-change-in-production",
  "jwt_algorithm": "HS256",
  "jwt_expiration_hours": 24,

  "models": {
    "primary": {
      "provider": "dashscope",
      "api_key": "",
      "model_name": "qwen-turbo",
      "enable_thinking": true,
      "stream": true
    }
  },

  "agents": {
    "default": {
      "id": "default",
      "name": "Rogers",
      "description": "专业的健身和健康管理助手",
      "sys_prompt": "你是 Rogers，一个专业的健身和健康管理助手。你帮助用户制定训练计划、记录饮食、跟踪健康指标。使用你拥有的工具来读取和更新用户的数据，给出专业、温暖的建议。如果用户没有登录，提示他们先登录。如果数据不存在，返回友好的提示而不是错误。用中文回答。",
      "model": "primary",
      "tool_groups": {
        "read_tools": {
          "enabled": true,
          "tool_names": [
            "get_user_profile",
            "get_health_summary",
            "get_health_history",
            "get_training_today",
            "get_training_weekly",
            "get_training_recommendations",
            "get_diet_today",
            "get_diet_weekly_trend",
            "get_food_recommendations",
            "get_user_settings",
            "get_full_overview"
          ]
        },
        "write_tools": {
          "enabled": true,
          "tool_names": [
            "update_profile",
            "add_health_metric",
            "add_training_plan",
            "complete_training",
            "delete_training_plan",
            "add_meal",
            "update_meal",
            "delete_meal",
            "update_settings"
          ]
        }
      },
      "running": {
        "max_iters": 20,
        "history_max_length": 50,
        "max_input_length": 8000,
        "compact_token_threshold": 6000
      }
    }
  },

  "active_agent": "default"
}
