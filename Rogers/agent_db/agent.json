{
  "app_name": "FitAgent",
  "app_version": "1.0.0",
  "debug": true,
  "server_host": "127.0.0.1",
  "server_port": 8000,
  "database_url": "sqlite:///./db/fitagent.db",
  "jwt_secret_key": "your-secret-key-change-in-production",
  "jwt_algorithm": "HS256",
  "jwt_expiration_hours": 24,

  "models": {
    "primary": {
      "provider": "dashscope",
      "api_key": "",
      "model_name": "qwen-turbo",
      "enable_thinking": true,
      "stream": true
    }
  },

  "agents": {
    "default": {
      "id": "default",
      "name": "Rogers",
      "description": "专业的健身和健康管理助手",
      "sys_prompt": "你是 Rogers，一个专业的健身和健康管理助手。你帮助用户制定训练计划、记录饮食、跟踪健康指标。使用你拥有的工具来读取和更新用户的数据，给出专业、温暖的建议。如果用户没有登录，提示他们先登录。如果数据不存在，返回友好的提示而不是错误。用中文回答。",
      "model": "primary",
      "tool_groups": {
        "read_tools": {
          "enabled": true,
          "tool_names": [
            "get_user_profile",
            "get_health_summary",
            "get_health_history",
            "get_training_today",
            "get_training_weekly",
            "get_training_recommendations",
            "get_diet_today",
            "get_diet_weekly_trend",
            "get_food_recommendations",
            "get_user_settings",
            "get_full_overview"
          ]
        },
        "write_tools": {
          "enabled": true,
          "tool_names": [
            "update_profile",
            "add_health_metric",
            "add_training_plan",
            "complete_training",
            "delete_training_plan",
            "add_meal",
            "update_meal",
            "delete_meal",
            "update_settings"
          ]
        }
      },
      "running": {
        "max_iters": 20,
        "history_max_length": 50,
        "max_input_length": 131072,
        "compact_token_threshold": 6000,
        "embedding_config": {
          "backend": "openai",
          "api_key": "",
          "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "model_name": "text-embedding-v3",
          "dimensions": 1024,
          "enable_cache": true,
          "use_dimensions": false,
          "max_cache_size": 3000,
          "max_input_length": 8192,
          "max_batch_size": 10
        },
        "context_compact": {
          "token_count_estimate_divisor": 3.75,
          "context_compact_enabled": true,
          "memory_compact_ratio": 0.75,
          "memory_reserve_ratio": 0.1,
          "compact_with_thinking_block": true
        },
        "tool_result_compact": {
          "enabled": true,
          "recent_n": 2,
          "old_max_bytes": 3000,
          "recent_max_bytes": 50000,
          "retention_days": 5
        },
        "memory_summary": {
          "memory_summary_enabled": true,
          "force_memory_search": false,
          "force_max_results": 1,
          "force_min_score": 0.3,
          "force_memory_search_timeout": 10.0,
          "rebuild_memory_index_on_start": false,
          "recursive_file_watcher": false
        }
      }
    }
  },

  "active_agent": "default"
}
