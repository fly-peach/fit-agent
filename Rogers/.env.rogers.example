# Rogers Agent - 环境配置示例
# 复制为 .env 并填入实际值

# ========== 必需配置 ==========
# 阿里云 DashScope API Key
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 模型配置 (可选) ==========
# 视觉模型 (默认: qwen-vl-max)
VISION_MODEL=qwen-vl-max

# 推理模型 (默认: qwen-max)
REASONING_MODEL=qwen-max

# ========== 服务器配置 (可选) ==========
HOST=127.0.0.1
PORT=8000

# ========== Pipeline 配置 (可选) ==========
# 是否启用子Agent分析 (默认: true)
FANOUT_ENABLED=true
