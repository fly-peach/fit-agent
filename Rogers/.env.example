# FitAgent 环境配置
# 复制为 .env 并填入实际值
# 生成密钥: python -c "import secrets; print(secrets.token_hex(32))"

# ========== LLM 模型配置 ==========
# API Key 不在此配置，请在「Agent 配置」页面填入
# 可选：指定默认模型名称
DASHSCOPE_MODEL=qwen-turbo

# 备用模型 - OpenAI 兼容接口（可选）
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# ========== 应用配置 ==========
APP_NAME=FitAgent
APP_VERSION=1.0.0

# ========== 数据库 ==========
# 默认使用 data/ 目录下的 SQLite，通常无需修改
# 如使用 PostgreSQL/MySQL：
# BASE_DB_URL=postgresql://user:pass@localhost:5432/fitbase
# USER_DB_URL=postgresql://user:pass@localhost:5432/fituser

# ========== JWT 配置 ==========
# 必填！使用下方命令生成随机密钥：
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ========== CORS 跨域 ==========
# 必填！逗号分隔允许的前端域名
CORS_ORIGINS=http://localhost:3000

# ========== 服务器 ==========
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
